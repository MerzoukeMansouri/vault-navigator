# This is an example environment file
# Copy this to .env.local and fill in your values

# Maintenance Mode
# Set to 'true' to enable maintenance mode, 'false' to disable
# When enabled, users will see a maintenance page instead of the app
NEXT_PUBLIC_MAINTENANCE_MODE=true

# Application URL
# Use the full URL where your app is deployed (including protocol and port if non-standard)
# Examples:
#   - Production: https://vault-navigator.yourdomain.com
#   - Development: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
